<Window x:Class="WinGrid11.Ui.SettingsWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinGrid11 Settings"
        Width="900"
        Height="820"
        MinWidth="720"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="#1B1B1F"
        Foreground="#E6E6E6"
        FontFamily="Segoe UI"
        FontSize="13"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#26262C" />
        <SolidColorBrush x:Key="BorderBrush" Color="#3A3A42" />
        <SolidColorBrush x:Key="AccentBrush" Color="#4080FF" />
        <SolidColorBrush x:Key="MutedBrush" Color="#999999" />
        <SolidColorBrush x:Key="TextBrush" Color="#E6E6E6" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Text" Value="" />
        </Style>

        <Style x:Key="SectionStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Padding" Value="6,0,0,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,4" />
        </Style>

        <Style TargetType="Slider">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1B1B1F" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#2E2E36" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#383841" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#22222A" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#5A95FF" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#5A95FF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#3878F0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel Margin="20">

        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="WinGrid11" FontSize="26" FontWeight="Light" />
                <TextBlock Grid.Column="1" x:Name="VersionLabel"
                           FontSize="13"
                           Foreground="{StaticResource MutedBrush}"
                           VerticalAlignment="Bottom" Margin="0,0,0,4" />
            </Grid>
            <TextBlock x:Name="StatusLine"
                       FontSize="12"
                       Foreground="{StaticResource MutedBrush}"
                       Margin="0,4,0,0"
                       TextWrapping="Wrap" />
        </StackPanel>

        <!-- Footer -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Close" Width="100" Height="32" Click="OnCloseClick" Style="{StaticResource AccentButton}" />
        </StackPanel>

        <!-- Body: two columns of sections + credits row spanning underneath. -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,8,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Left column: Behavior + Grid -->
                <StackPanel Grid.Column="0" Grid.Row="0">

                <!-- Behavior section -->
                <Border Style="{StaticResource SectionStyle}">
                    <StackPanel>
                        <TextBlock Text="BEHAVIOR" Style="{StaticResource HeaderStyle}" />

                        <CheckBox x:Name="FreeResizeBox" Content="Free resize (no grid)"
                                  Checked="OnBoolToggled" Unchecked="OnBoolToggled"
                                  ToolTip="Pick a pixel-precise rectangle instead of snapping to grid cells." />

                        <CheckBox x:Name="RmbAgainBox" Content="Right-click again switches to free resize"
                                  Checked="OnBoolToggled" Unchecked="OnBoolToggled"
                                  ToolTip="In grid mode, click RMB again after the grid appears to finish the gesture in free resize, anchored at the grid's start cell." />

                        <CheckBox x:Name="KeepOnScreenBox" Content="Keep windows on screen"
                                  Checked="OnBoolToggled" Unchecked="OnBoolToggled"
                                  ToolTip="If the window's minimum size pushes it past a screen edge, shift it back into view." />

                        <CheckBox x:Name="BlockInteractionBox" Content="Block cursor from background apps"
                                  Checked="OnBoolToggled" Unchecked="OnBoolToggled"
                                  ToolTip="Prevent the cursor from interacting with apps under the grid overlay." />

                        <CheckBox x:Name="LiveResizeBox" Content="Resize window during gesture"
                                  Checked="OnBoolToggled" Unchecked="OnBoolToggled"
                                  Margin="0,12,0,0"
                                  ToolTip="Resize the window live during the gesture instead of on release." />
                        <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="11"
                                   TextWrapping="Wrap" Margin="22,2,0,0"
                                   Text="Similar to WindowGrid method. May break content in Electron/Chromium apps (Cursor, VS Code, Discord, Slack) and custom-renderer apps (FilePilot)." />
                    </StackPanel>
                </Border>

                <!-- Grid section -->
                <Border Style="{StaticResource SectionStyle}">
                    <StackPanel>
                        <TextBlock Text="GRID" Style="{StaticResource HeaderStyle}" />

                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Columns" VerticalAlignment="Center"
                                       ToolTip="Number of columns in the grid. Portrait monitors swap columns and rows." />
                            <Slider Grid.Column="1" x:Name="ColumnsSlider" Minimum="1" Maximum="32" TickFrequency="1" IsSnapToTickEnabled="True"
                                    SmallChange="1" LargeChange="2" ValueChanged="OnGridChanged" Margin="8,0"
                                    ToolTip="Number of columns in the grid. Portrait monitors swap columns and rows." />
                            <TextBlock Grid.Column="2" x:Name="ColumnsValue" VerticalAlignment="Center" HorizontalAlignment="Right" />
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Rows" VerticalAlignment="Center"
                                       ToolTip="Number of rows in the grid. Portrait monitors swap columns and rows." />
                            <Slider Grid.Column="1" x:Name="RowsSlider" Minimum="1" Maximum="32" TickFrequency="1" IsSnapToTickEnabled="True"
                                    SmallChange="1" LargeChange="2" ValueChanged="OnGridChanged" Margin="8,0"
                                    ToolTip="Number of rows in the grid. Portrait monitors swap columns and rows." />
                            <TextBlock Grid.Column="2" x:Name="RowsValue" VerticalAlignment="Center" HorizontalAlignment="Right" />
                        </Grid>
                        <DockPanel Margin="0,8,0,0">
                            <!-- Button first so it actually docks right; otherwise
                                 LastChildFill makes it stretch over the text. -->
                            <Button DockPanel.Dock="Right" Content="Reset" Width="80"
                                    Margin="12,0,0,0"
                                    Click="OnResetGrid"
                                    ToolTip="Reset columns and rows to the default 12 by 6." />
                            <TextBlock Text="Portrait monitors auto-transpose: rows become columns and vice versa."
                                       Foreground="{StaticResource MutedBrush}" FontSize="11" TextWrapping="Wrap"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                    </StackPanel>
                </Border>

                </StackPanel>

                <!-- Right column: Appearance + System -->
                <StackPanel Grid.Column="2" Grid.Row="0">

                <!-- Appearance section -->
                <Border Style="{StaticResource SectionStyle}">
                    <StackPanel>
                        <TextBlock Text="APPEARANCE" Style="{StaticResource HeaderStyle}" />
                        <TextBlock Text="Hex colors. Format #RRGGBB or #AARRGGBB."
                                   Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,8" />

                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="32" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Cell fill" VerticalAlignment="Center"
                                       ToolTip="Color of unselected grid cells." />
                            <TextBox Grid.Column="1" x:Name="CellColorBox" TextChanged="OnColorChanged" Margin="8,0"
                                     ToolTip="Color of unselected grid cells." />
                            <Border Grid.Column="2" x:Name="CellSwatch" CornerRadius="4" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" />
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="32" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Highlight" VerticalAlignment="Center"
                                       ToolTip="Color of selected cells and the free-resize preview rectangle." />
                            <TextBox Grid.Column="1" x:Name="HighlightColorBox" TextChanged="OnColorChanged" Margin="8,0"
                                     ToolTip="Color of selected cells and the free-resize preview rectangle." />
                            <Border Grid.Column="2" x:Name="HighlightSwatch" CornerRadius="4" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" />
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="32" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Stroke" VerticalAlignment="Center"
                                       ToolTip="Color of cell borders and preview rectangle outline." />
                            <TextBox Grid.Column="1" x:Name="StrokeColorBox" TextChanged="OnColorChanged" Margin="8,0"
                                     ToolTip="Color of cell borders and preview rectangle outline." />
                            <Border Grid.Column="2" x:Name="StrokeSwatch" CornerRadius="4" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- System section -->
                <Border Style="{StaticResource SectionStyle}">
                    <StackPanel>
                        <TextBlock Text="SYSTEM" Style="{StaticResource HeaderStyle}" />

                        <CheckBox x:Name="AutoStartBox" Content="Launch on Windows startup"
                                  Checked="OnAutoStartToggled" Unchecked="OnAutoStartToggled"
                                  ToolTip="Start WinGrid11 automatically when you sign in. Stored in the per-user Run key." />

                        <Button Content="Reset gesture (Ctrl+Alt+Shift+Q)" Click="OnResetGesture"
                                HorizontalAlignment="Stretch" Margin="0,12,0,4"
                                ToolTip="Force the gesture state machine back to idle. Use if a gesture got stuck." />
                        <Button x:Name="ElevateButton" Content="Restart as administrator" Click="OnRestartElevated"
                                HorizontalAlignment="Stretch" Margin="0,4"
                                ToolTip="Relaunch with admin rights so WinGrid11 can manage Task Manager, regedit, and other elevated apps." />
                        <Button Content="Open settings folder" Click="OnOpenSettingsFolder"
                                HorizontalAlignment="Stretch" Margin="0,4"
                                ToolTip="Open the folder containing settings.json." />
                        <Button Content="Exit WinGrid11" Click="OnExitClick"
                                HorizontalAlignment="Stretch" Margin="0,4"
                                ToolTip="Quit WinGrid11. The gesture stops working until relaunched." />
                    </StackPanel>
                </Border>

                </StackPanel>

                <!-- How to use - bottom-left column. -->
                <Border Grid.Column="0" Grid.Row="1" Style="{StaticResource SectionStyle}">
                    <StackPanel>
                        <TextBlock Text="HOW TO USE" Style="{StaticResource HeaderStyle}" />
                        <TextBlock TextWrapping="Wrap" LineHeight="20">
                            <Run FontWeight="SemiBold" Text="1." />
                            <Run Text=" Hold left-click on a window's title bar and start dragging." />
                            <LineBreak />
                            <Run FontWeight="SemiBold" Text="2." />
                            <Run Text=" While still holding, tap right-click. The grid appears on every monitor." />
                            <LineBreak />
                            <Run FontWeight="SemiBold" Text="3." />
                            <Run Text=" Drag to the opposite corner of the rectangle you want." />
                            <LineBreak />
                            <Run FontWeight="SemiBold" Text="4." />
                            <Run Text=" Release left-click. The window snaps to that rectangle." />
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="11"
                                   TextWrapping="Wrap" Margin="0,10,0,0"
                                   Text="Tip: if a gesture ever feels stuck, press Ctrl+Alt+Shift+Q to reset." />
                    </StackPanel>
                </Border>

                <!-- Credits - bottom-right column. -->
                <Border Grid.Column="2" Grid.Row="1" Style="{StaticResource SectionStyle}">
                    <StackPanel>
                        <TextBlock Text="CREDITS" Style="{StaticResource HeaderStyle}" />
                        <TextBlock TextWrapping="Wrap" LineHeight="20">
                            <Run Text="Heavily inspired by the great work of Joshua Wilding! The original WindowGrid was an amazing tool that changed how I use Windows. Sadly, it is pretty inconsistent on Windows 11 and with newer apps. This tool aims to address that! Check out the original WindowGrid at " />
                            <Hyperlink NavigateUri="http://windowgrid.net"
                                       Foreground="{StaticResource AccentBrush}"
                                       RequestNavigate="OnHyperlinkNavigate">windowgrid.net</Hyperlink>
                            <Run Text="." />
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
